# Zyme configuration.
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# The app auto-loads `.env` on startup — no need to export vars manually.
# (Already-set env vars take precedence over `.env`.)

# ── Postgres (required) ──────────────────────────────────────────────
# The zyme-pg Docker container (pgvector/pgvector:pg16).
ZYME_PG_DSN=postgres://postgres:postgres@localhost:5432/zyme?sslmode=disable

# ── Ollama (embedding) ──────────────────────────────────────────────
# The ollama-full tray app must be running on this host.
ZYME_OLLAMA_URL=http://localhost:11434
ZYME_EMBED_MODEL=bge-m3
# NOTE: embedding dim is fixed at 1024 to match bge-m3 and the schema's
# vector(1024) column. Changing the model means editing the dim in
# internal/store/schema.sql and re-migrating.

# ── Obsidian vault (for `materialize` / `sync`) ─────────────────────
# Root of the vault Obsidian opens. Zyme writes to <vault>/_zyme/.
ZYME_VAULT=D:/Coding/zyme/vault

# ── Track A snapshot storage ────────────────────────────────────────
# Content-addressed raw payloads (html/json/...). Relative to cwd.
ZYME_SNAPSHOT_DIR=./data/snapshots

# ── GitHub adapter (for `zyme ingest --adapter github --url starred`) ──
# Personal access token: Settings → Developer settings → Personal access
# tokens → Tokens (classic) → Generate. Scope: public_repo (public stars)
# or repo (private stars). Leave empty to disable the github adapter.
ZYME_GITHUB_TOKEN=
# Optional: cap how many starred repos to import per run (0 = all).
ZYME_GITHUB_LIMIT=0
