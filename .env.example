# Zyme config. Copy to .env and fill in. Loaded from environment variables.

# Postgres (required). Create the db first:  createdb zyme
# Needs the pgvector extension installed for your Postgres version.
ZYME_PG_DSN=postgres://postgres:postgres@localhost:5432/zyme?sslmode=disable

# Ollama (required for embedding). Start:  ollama serve   then:  ollama pull bge-m3
ZYME_OLLAMA_URL=http://localhost:11434
ZYME_EMBED_MODEL=bge-m3

# Obsidian vault root. The materialize step writes derived nodes into <vault>/_zyme/.
ZYME_VAULT=D:\path\to\your\vault

# Track A snapshot storage (content-addressed blobs).
ZYME_SNAPSHOT_DIR=./data/snapshots
